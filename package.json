{
	"name": "calurcap",
	"private": true,
	"version": "0.0.1",
	"type": "module",
	"workspaces": [
		"packages/kainbu-cli",
		"packages/kainbu-core"
	],
	"engines": {
		"node": "22.x"
	},
	"scripts": {
		"api:dev": "node scripts/free-port.mjs && tsx watch server/index.ts",
		"api:start": "node scripts/free-port.mjs && tsx server/index.ts",
		"dev": "vite dev --host --port 3001",
		"dev:lan": "vite dev --host 0.0.0.0 --port 3000",
		"dev:full": "concurrently -k \"npm run api:dev\" \"npm run dev\"",
		"dev:android": "npx cap run android -l --port=3000 --host=192.168.0.9",
		"build": "vite build",
		"build:apk:release": "node scripts/build-android-release.mjs",
		"postinstall": "node scripts/patch-svelte-dnd-action.mjs",
		"preview": "vite preview",
		"prepare": "svelte-kit sync || echo ''",
		"check": "svelte-kit sync && svelte-check --tsconfig ./tsconfig.json",
		"check:server": "tsc -p tsconfig.server.json --noEmit",
		"check:watch": "svelte-kit sync && svelte-check --tsconfig ./tsconfig.json --watch",
		"lint": "eslint . && prettier --check .",
		"format": "prettier --write .",
		"setup": "node setup.js",
		"test:deploy": "vitest run tests/deploy.test.ts",
		"cli:build": "npm run build --workspace=kainbu",
		"cli:link": "npm run build --workspace=kainbu && npm link --workspace=kainbu",
		"test:cli": "vitest run tests/cliContext.test.ts tests/cliBoardList.test.ts tests/cliDeviceAuth.test.ts"
	},
	"devDependencies": {
		"@capacitor/assets": "^3.0.5",
		"@eslint/compat": "^1.4.0",
		"@eslint/js": "^9.39.1",
		"@sveltejs/adapter-auto": "^7.0.0",
		"@sveltejs/kit": "^2.48.5",
		"@sveltejs/vite-plugin-svelte": "^6.2.1",
		"@tailwindcss/vite": "^4.1.17",
		"@types/node": "^20",
		"autoprefixer": "^10.4.22",
		"concurrently": "^9.2.1",
		"esbuild": "^0.27.7",
		"eslint": "^9.39.1",
		"eslint-config-prettier": "^10.1.8",
		"eslint-plugin-svelte": "^3.13.0",
		"globals": "^16.5.0",
		"postcss": "^8.5.6",
		"prettier": "^3.6.2",
		"prettier-plugin-svelte": "^3.4.0",
		"prettier-plugin-tailwindcss": "^0.7.1",
		"svelte": "^5.43.8",
		"svelte-check": "^4.3.4",
		"tailwindcss": "^4.1.17",
		"tsx": "^4.21.0",
		"typescript": "^5.9.3",
		"typescript-eslint": "^8.47.0",
		"vite": "^8.0.2",
		"vitest": "^4.1.2"
	},
	"dependencies": {
		"@capacitor/android": "^7.4.4",
		"@capacitor/app": "^7.1.0",
		"@capacitor/browser": "^7.0.2",
		"@capacitor/cli": "^7.4.4",
		"@capacitor/core": "^7.4.4",
		"@codetrix-studio/capacitor-google-auth": "^3.4.0-rc.4",
		"@hono/node-server": "^1.19.11",
		"@iconify/svelte": "^5.2.1",
		"pocketbase": "^0.25.2",
		"@sveltejs/adapter-static": "^3.0.10",
		"@tiptap/core": "^3.22.2",
		"@tiptap/extension-code-block-lowlight": "^3.22.2",
		"@tiptap/extension-image": "^3.22.2",
		"@tiptap/extension-link": "^3.22.2",
		"@tiptap/extension-placeholder": "^3.22.2",
		"@tiptap/extension-task-item": "^3.22.2",
		"@tiptap/extension-task-list": "^3.22.2",
		"@tiptap/markdown": "^3.22.2",
		"@tiptap/pm": "^3.22.2",
		"@tiptap/starter-kit": "^3.22.2",
		"@tiptap/suggestion": "^3.22.2",
		"dompurify": "^3.3.3",
		"dotenv": "^17.3.1",
		"highlight.js": "^11.11.1",
		"hono": "^4.12.8",
		"lowlight": "^3.3.0",
		"lucide-svelte": "^0.577.0",
		"marked": "^17.0.5",
		"sharp": "^0.34.5",
		"svelte-dnd-action": "^0.9.69"
	}
}
