{
	"buildCommand": "npm run build",
	"outputDirectory": "build",
	"functions": {
		"api/index.js": {
			"maxDuration": 60
		},
		"api/health.js": {
			"maxDuration": 60
		},
		"api/workspace/**/*.js": {
			"includeFiles": "server/**/*",
			"maxDuration": 60
		},
		"api/workspace-ai.js": {
			"includeFiles": "server/**/*",
			"maxDuration": 60
		}
	},
	"rewrites": [
		{
			"source": "/health",
			"destination": "/api/health"
		}
	]
}
