# Paste into Dokploy → Kainbu compose → Environment (UI supports multiline; CLI does not).
# Do NOT set VITE_POCKETBASE_URL unless PocketBase is on a separate public host.
# Browser uses https://your-domain/pb via nginx.

POCKETBASE_URL=http://pocketbase:8090
POCKETBASE_ADMIN_EMAIL=admin@kainbu.local
POCKETBASE_ADMIN_PASSWORD=change-me
OPENROUTER_API_KEY=
KAINBU_ADMIN_EMAILS=you@example.com
KAINBU_PUBLIC_URL=https://kainbu.avarnic.com
# Do not publish host ports in compose; map domain → web:80 in Dokploy only.
