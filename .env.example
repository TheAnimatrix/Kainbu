# Web app (Vite) — optional. Docker: leave unset; browser uses https://your-domain/pb via nginx.
# Local dev without Docker: http://127.0.0.1:8090
# VITE_POCKETBASE_URL=http://127.0.0.1:8090

# API server (Docker: use service name; local: 127.0.0.1)
POCKETBASE_URL=http://127.0.0.1:8090
POCKETBASE_ADMIN_EMAIL=admin@kainbu.local
POCKETBASE_ADMIN_PASSWORD=kainbu-admin-change-me
OPENROUTER_API_KEY=
# Vercel AI Gateway key, used for models whose provider is set to "vercel" in the admin panel.
# Admin-saved keys (AI key tab) take precedence over these env vars.
AI_GATEWAY_API_KEY=

# Comma-separated emails that receive in-app admin access (synced to users.is_admin)
KAINBU_ADMIN_EMAILS=admin-e2e@kainbu.test

# Public URL for CLI device login links
KAINBU_PUBLIC_URL=http://localhost:3000

# HTTP abuse controls (restart API after changing these)
# Comma-separated exact origins; never use '*' when credentials are enabled.
KAINBU_CORS_ORIGINS=http://localhost:3000
# Only enable when the API is reachable exclusively through a trusted proxy.
KAINBU_TRUST_PROXY=false
KAINBU_RATE_LIMIT=120
KAINBU_RATE_WINDOW_MS=60000
KAINBU_RATE_LIMIT_ENTRIES=10000
KAINBU_MAX_JSON_BYTES=2097152
KAINBU_MAX_AI_JSON_BYTES=10485760
KAINBU_MAX_TRANSCRIPTION_JSON_BYTES=12582912

# Optional CLI overrides
# KAINBU_POCKETBASE_URL=
# KAINBU_API_BASE=http://127.0.0.1:8788
