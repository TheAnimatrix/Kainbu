# Web app (Vite) — also read by the kainbu CLI
VITE_SUPABASE_URL=https://your-project.supabase.co
VITE_SUPABASE_ANON_KEY=your-anon-key

# Optional CLI-specific names (e.g. in ~/.config/kainbu/.env)
# KAINBU_SUPABASE_URL=
# KAINBU_SUPABASE_ANON_KEY=
# KAINBU_API_BASE=http://127.0.0.1:8788

# Server only
# SUPABASE_SERVICE_ROLE_KEY=
